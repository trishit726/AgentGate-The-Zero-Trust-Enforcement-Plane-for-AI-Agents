# AgentGate environment — copy to .env and fill in. NEVER commit the real .env.
# JWT signing secret for scoped agent identity tokens (HS256). >= 32 random chars.
AGENTGATE_JWT_SECRET=change-me-to-a-long-random-32char-minimum-secret

# Splunk HTTP Event Collector — decision + investigation events land here.
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=<your-hec-token>
# Sourcetype must match what the MCP TA expects (verify in the TA's props.conf).
SPLUNK_HEC_SOURCETYPE=mcp:jsonrpc

# Splunk MCP Server (Phase 2 — Sentinel).
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
# Paste the encrypted MCP token as ONE unbroken line — no spaces, no newlines.
SPLUNK_MCP_TOKEN=<your-encrypted-mcp-token-one-line>

# Local TLS is self-signed for localhost Splunk; false disables verification.
SPLUNK_VERIFY_TLS=false

# Splunk admin login — used only by scripts/deploy_splunk.py (REST deploy of the
# correlation rules + dashboard).
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=<your-splunk-password>

# Ollama serving Foundation-Sec locally (Phase 2). The tag below is the GGUF build
# this project was verified with.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/fdtn-ai/Foundation-Sec-1.1-8B-Instruct-Q4_K_M-GGUF
